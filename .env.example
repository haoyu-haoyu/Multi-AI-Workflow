# =============================================================================
# Multi-AI Workflow (MAW) Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# All variables are optional — defaults are shown.

# ---------------------------------------------------------------------------
# General
# ---------------------------------------------------------------------------

# Maximum execution time for a single AI operation (ms)
MAW_TIMEOUT=120000

# Log level: debug | info | warn | error
MAW_LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Dashboard
# ---------------------------------------------------------------------------

# Dashboard server port
MAW_DASHBOARD_PORT=3100

# Bearer token for dashboard API authentication (leave empty to disable)
MAW_DASHBOARD_TOKEN=

# Allowed CORS origins (comma-separated)
MAW_CORS_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# AI Providers (set only the ones you use)
# ---------------------------------------------------------------------------

# Gemini API key (for Gemini bridge)
# GEMINI_API_KEY=

# Codex API key (for Codex bridge)
# CODEX_API_KEY=

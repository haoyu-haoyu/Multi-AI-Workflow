# =============================================================================
# Multi-AI Workflow (MAW) Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# All variables are optional unless noted.

# ---------------------------------------------------------------------------
# Dashboard
# ---------------------------------------------------------------------------

# Dashboard server port (default: 3000)
MAW_DASHBOARD_PORT=3000

# Bearer token for dashboard API authentication (leave empty to disable)
MAW_DASHBOARD_TOKEN=

# Allowed CORS origins (comma-separated)
MAW_CORS_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------

# Default sandbox level: read-only | workspace-write | danger-full-access
MAW_SANDBOX_LEVEL=workspace-write

# ---------------------------------------------------------------------------
# AI Provider API Keys (set only the ones you use)
# ---------------------------------------------------------------------------

# Codex API key
# MAW_CODEX_API_KEY=

# Gemini API key (MAW_GEMINI_API_KEY takes precedence over GEMINI_API_KEY)
# MAW_GEMINI_API_KEY=
# GEMINI_API_KEY=
